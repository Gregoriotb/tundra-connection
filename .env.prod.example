# ─────────────────────────────────────────────────────────────────────────────
# Tundra Connection — Smoke test prod local (FASE 11 paso A5)
#
# Copiar a .env.prod (gitignored) y rellenar antes de:
#   docker compose -f docker-compose.prod.yml --env-file .env.prod up --build
# ─────────────────────────────────────────────────────────────────────────────

# Required — el compose falla si falta o usa valor de ejemplo.
# Generar: openssl rand -hex 64
SECRET_KEY=

# Required — password del Postgres local. NO usar el valor de dev.
# Generar: openssl rand -base64 32
POSTGRES_PASSWORD=

# Default localhost frontend. Cambiar si pruebas con otro dominio.
FRONTEND_URL=http://localhost:5173

# Opcionales — dejar vacíos para validar modo maqueta.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=
IMGBB_API_KEY=
RESEND_API_KEY=
EMAIL_FROM=noreply@tundraconnection.com

LOG_LEVEL=INFO
