# ─────────────────────────────────────────────────────────────────────────────
# Tundra Connection — Backend env vars (FASE 11)
#
# Copiar a .env (dev local) o configurar como env vars en Railway (prod).
# NO commitear .env real. Esta plantilla SÍ se commitea.
# ─────────────────────────────────────────────────────────────────────────────

# ── Core ──────────────────────────────────────────────────────────────────
# `production` activa assert_production_safe() — falla si hay secretos vacíos.
ENVIRONMENT=development

# Mínimo 64 chars random. Generar: openssl rand -hex 64
SECRET_KEY=cambia-este-valor-por-uno-aleatorio-de-minimo-64-caracteres-xxxxxxxxxxxxxxxxxx

# URL pública del frontend (sin "/" final). En prod: https://tundra.vercel.app
FRONTEND_URL=http://localhost:5173

# ── Database (Neon en prod) ───────────────────────────────────────────────
# Local: docker-compose levanta Postgres en `db`
# Neon: postgresql://user:pass@ep-xxx.neon.tech/dbname?sslmode=require
DATABASE_URL=postgresql://tundra:tundra_dev@db:5432/tundra_connection

# ── JWT ───────────────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440
JWT_REFRESH_TOKEN_EXPIRE_DAYS=30

# ── Google OAuth (FASE 7 — sweep FASE 11) ─────────────────────────────────
# Crear credenciales en https://console.cloud.google.com → OAuth consent screen
# Authorized redirect URIs debe incluir GOOGLE_REDIRECT_URI exacta.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# ── ImgBB (FASE 7 — sweep FASE 11) ────────────────────────────────────────
# Si está vacío, upload_service usa fallback local en UPLOAD_LOCAL_DIR.
# Crear API key en https://api.imgbb.com → "Get API key"
IMGBB_API_KEY=
UPLOAD_LOCAL_DIR=/app/uploads
UPLOAD_MAX_SIZE_MB=10

# ── Grafana SELF-HOSTED (FASE 9 — sweep FASE 11) ──────────────────────────
# Ej: https://grafana.tundra.local  (sin "/" final)
# Token: en Grafana → Administration → Service accounts → Add service account
GRAFANA_URL=
GRAFANA_SERVICE_ACCOUNT_TOKEN=

# ── Email (FASE 10 — sweep FASE 11) ───────────────────────────────────────
# Provider por decidir (Resend / SES / SMTP propio).
# Mientras esté vacío, el email se loguea + escribe a uploads/_emails_outbox/
RESEND_API_KEY=
EMAIL_FROM=noreply@tundraconnection.com

# ── Rate limiting (R12 — formato slowapi) ─────────────────────────────────
RATE_LIMIT_LOGIN=5/minute
RATE_LIMIT_REGISTER=3/minute
RATE_LIMIT_DEFAULT=60/minute

# ── Logging ───────────────────────────────────────────────────────────────
LOG_LEVEL=INFO

# ── Railway-specific ──────────────────────────────────────────────────────
# Railway inyecta $PORT en runtime — el Dockerfile ya lo respeta.
# No definir PORT acá manualmente.
